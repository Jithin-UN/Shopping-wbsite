rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - category: string (required)
    //   - imageUrl: string (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string ('user', 'admin') (required)
    //   - address: string (optional)
    //   - phone: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - status: string ('pending', 'completed', 'shipped') (required)
    //   - shippingAddress: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: 'shipping'
    // Fields:
    //   - freeOrdersCount: number (required)
    //   - freeShippingThreshold: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         request.auth.token.email == "jithinullodi@gmail.com");
    }

    function isValidProduct(data) {
      let requiredFields = ['name', 'price', 'category', 'imageUrl', 'stock'];
      let allowedFields = ['name', 'price', 'category', 'imageUrl', 'description', 'stock', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             data.category is string && data.category.size() > 0 &&
             data.imageUrl is string && (data.imageUrl.matches("^https?://.*") || data.imageUrl.matches("^data:image/.*")) &&
             (!('description' in data) || data.description is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt is string);
    }

    function isValidUser(data) {
      let requiredFields = ['uid', 'email', 'role'];
      let allowedFields = ['uid', 'email', 'displayName', 'fullName', 'role', 'address', 'city', 'state', 'postalCode', 'phone', 'favorites', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['user', 'admin'] &&
             (!('favorites' in data) || data.favorites is list);
    }

    function isValidOrder(data) {
      let requiredFields = ['orderId', 'userId', 'items', 'totalAmount', 'status', 'shippingDetails', 'paymentMethod'];
      let allowedFields = ['orderId', 'userId', 'items', 'totalAmount', 'status', 'shippingDetails', 'paymentMethod', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled', 'completed'] &&
             data.shippingDetails is map &&
             data.paymentMethod is string;
    }

    // Rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
